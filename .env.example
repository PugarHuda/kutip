# ======================================
# Kutip — Environment Variables Template
# ======================================
# Copy this file to .env and fill in values.
# NEVER commit .env (already in .gitignore)

# ---- Kite Testnet ----
KITE_RPC_URL=https://rpc-testnet.gokite.ai/
KITE_CHAIN_ID=2368
KITE_EXPLORER_URL=https://testnet.kitescan.ai/

# ---- Your deployer wallet (get KITE from faucet.gokite.ai) ----
PRIVATE_KEY=0x_your_private_key_here

# ---- Contracts (filled after `forge script Deploy`) ----
ATTRIBUTION_LEDGER_ADDRESS=
KITE_TESTNET_USDC=0x0fF5393387ad2f9f691FD6Fd28e07E3969e27e63

# ---- x402 / Pieverse Facilitator ----
PIEVERSE_FACILITATOR_URL=https://facilitator.pieverse.io
PIEVERSE_TESTNET_SETTLE_ADDR=0x12343e649e6b2b2b77649DFAb88f103c02F3C78b

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=sk-ant-_your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Next.js ----
NEXT_PUBLIC_KITE_EXPLORER=https://testnet.kitescan.ai
NEXT_PUBLIC_ATTRIBUTION_LEDGER=
NEXT_PUBLIC_AGENT_OPERATOR_ADDRESS=
NEXT_PUBLIC_ECOSYSTEM_FUND_ADDRESS=

# ---- Revenue Split (basis points, must sum to 10000) ----
OPERATOR_BPS=5000
AUTHORS_BPS=4000
ECOSYSTEM_BPS=1000

# ---- Default Query Price (USDC, 6 decimals) ----
DEFAULT_QUERY_PRICE=2000000
